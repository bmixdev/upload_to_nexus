<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=windows-1251" />
  <meta http-equiv="x-ua-compatible" content="IE=9" />
  <title>Nexus Raw Uploader</title>
  <HTA:APPLICATION
    APPLICATIONNAME="NexusRawUploader"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal"
    SCROLL="no"
  />
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 14px; font-size: 13px; }
    h2 { margin: 0 0 12px 0; }
    .row { margin-bottom: 10px; }
    .lbl { display: inline-block; width: 180px; vertical-align: top; padding-top: 6px; }
    .ctrl { width: 640px; box-sizing: border-box; padding: 5px; }
    #filePath { width: 520px; }
    button { padding: 6px 12px; margin-right: 6px; }
    #memo { width: 824px; height: 280px; font-family: Consolas, monospace; font-size: 12px; white-space: pre; }
    .hint { color: #555; font-size: 12px; margin-top: 2px; margin-left: 184px; }
  </style>
  <script language="javascript" type="text/javascript">
    function $(id) { return document.getElementById(id); }

    function nowTs() {
      var d = new Date();
      function pad(n){ return (n < 10 ? "0" : "") + n; }
      return d.getFullYear() + "-" + pad(d.getMonth()+1) + "-" + pad(d.getDate()) + " " + pad(d.getHours()) + ":" + pad(d.getMinutes()) + ":" + pad(d.getSeconds());
    }

    function logLine(msg) {
      var area = $("memo");
      area.value += "[" + nowTs() + "] " + msg + "\r\n";
      area.scrollTop = area.scrollHeight;
    }

    function clearLog() {
      $("memo").value = "";
    }

    function escapePsSingleQuoted(value) {
      return String(value).replace(/'/g, "''");
    }

    function joinUrl(base, subPath, fileName) {
      var b = String(base || "").replace(/\s+$/g, "").replace(/\/+$/g, "");
      var s = String(subPath || "").replace(/^\/+|\/+$/g, "");
      var f = String(fileName || "").replace(/^\/+|\/+$/g, "");
      if (s.length > 0) return b + "/" + s + "/" + f;
      return b + "/" + f;
    }

    function getFileName(fullPath) {
      var p = String(fullPath || "");
      var i = Math.max(p.lastIndexOf("\\"), p.lastIndexOf("/"));
      return i >= 0 ? p.substring(i + 1) : p;
    }

    function runPsAndCapture(psScript) {
      var shell = new ActiveXObject("WScript.Shell");
      var wrapped = "[Console]::InputEncoding=[Text.Encoding]::GetEncoding(1251);" +
                    "[Console]::OutputEncoding=[Text.Encoding]::GetEncoding(1251);" +
                    "$OutputEncoding=[Text.Encoding]::GetEncoding(1251);" +
                    psScript;
      var utf16le = unescape(encodeURIComponent(wrapped));
      var i, bytes = [];
      for (i = 0; i < utf16le.length; i++) {
        var c = utf16le.charCodeAt(i);
        bytes.push(c & 0xFF);
        bytes.push((c >> 8) & 0xFF);
      }
      var b64 = base64FromBytes(bytes);
      var cmd = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -EncodedCommand ' + b64;
      var exec = shell.Exec(cmd);
      var out = exec.StdOut.ReadAll();
      var err = exec.StdErr.ReadAll();
      var code = exec.ExitCode;
      return { exitCode: code, stdout: out, stderr: err };
    }

    function base64FromBytes(bytes) {
      var table = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
      var result = "";
      var i;

      for (i = 0; i < bytes.length; i += 3) {
        var b1 = bytes[i];
        var b2 = (i + 1 < bytes.length) ? bytes[i + 1] : NaN;
        var b3 = (i + 2 < bytes.length) ? bytes[i + 2] : NaN;

        var c1 = b1 >> 2;
        var c2 = ((b1 & 3) << 4) | (isNaN(b2) ? 0 : (b2 >> 4));
        var c3 = isNaN(b2) ? 64 : (((b2 & 15) << 2) | (isNaN(b3) ? 0 : (b3 >> 6)));
        var c4 = isNaN(b3) ? 64 : (b3 & 63);

        result += table.charAt(c1);
        result += table.charAt(c2);
        result += (c3 === 64 ? "=" : table.charAt(c3));
        result += (c4 === 64 ? "=" : table.charAt(c4));
      }

      return result;
    }

    function pickFile() {
      try {
        var ps = "Add-Type -AssemblyName System.Windows.Forms;" +
                 "$dlg = New-Object System.Windows.Forms.OpenFileDialog;" +
                 "$dlg.Multiselect = $false;" +
                 "if ($dlg.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { Write-Output $dlg.FileName }";
        var res = runPsAndCapture(ps);
        if (res.exitCode !== 0) {
          logLine("ОШИБКА выбора файла: " + (res.stderr || "неизвестная ошибка"));
          return;
        }
        var filePath = String(res.stdout || "").replace(/\r?\n/g, "").replace(/^\s+|\s+$/g, "");
        if (filePath.length > 0) {
          $("filePath").value = filePath;
          logLine("Выбран файл: " + filePath);
        }
      } catch (e) {
        logLine("ОШИБКА: не удалось открыть диалог выбора файла: " + e.message);
      }
    }

    function parseJsonSafe(text) {
      try {
        return eval("(" + text + ")");
      } catch (e) {
        return null;
      }
    }

    function doDelete(url, user, pass) {
      var ps =
        "$ProgressPreference='SilentlyContinue';" +
        "$url='" + escapePsSingleQuoted(url) + "';" +
        "$user='" + escapePsSingleQuoted(user) + "';" +
        "$pass='" + escapePsSingleQuoted(pass) + "';" +
        "$pair = '{0}:{1}' -f $user,$pass;" +
        "$enc=[Text.Encoding]::GetEncoding(1251);" +
        "$token=[Convert]::ToBase64String($enc.GetBytes($pair));" +
        "$headers=@{ Authorization = 'Basic ' + $token };" +
        "$code=-1; $msg='';" +
        "try {" +
        "  $resp=Invoke-WebRequest -Uri $url -Method Delete -Headers $headers -UseBasicParsing -ErrorAction Stop;" +
        "  $code=[int]$resp.StatusCode; $msg='DELETE выполнен';" +
        "} catch {" +
        "  if ($_.Exception.Response) { try { $code=[int]$_.Exception.Response.StatusCode.value__ } catch { $code=-1 } } else { $code=-1 };" +
        "  $msg=$_.Exception.Message;" +
        "}" +
        "$obj=@{ step='DELETE'; code=$code; message=$msg };" +
        "$obj | ConvertTo-Json -Compress";

      return runPsAndCapture(ps);
    }

    function doUpload(url, user, pass, filePath) {
      var ps =
        "$ProgressPreference='SilentlyContinue';" +
        "$url='" + escapePsSingleQuoted(url) + "';" +
        "$user='" + escapePsSingleQuoted(user) + "';" +
        "$pass='" + escapePsSingleQuoted(pass) + "';" +
        "$file='" + escapePsSingleQuoted(filePath) + "';" +
        "if (-not (Test-Path -LiteralPath $file)) { throw 'Файл не найден: ' + $file }" +
        "$pair = '{0}:{1}' -f $user,$pass;" +
        "$enc=[Text.Encoding]::GetEncoding(1251);" +
        "$token=[Convert]::ToBase64String($enc.GetBytes($pair));" +
        "$headers=@{ Authorization = 'Basic ' + $token };" +
        "$code=-1; $msg='';" +
        "try {" +
        "  $resp=Invoke-WebRequest -Uri $url -Method Put -Headers $headers -InFile $file -ContentType 'application/octet-stream' -UseBasicParsing -ErrorAction Stop;" +
        "  $code=[int]$resp.StatusCode; $msg='UPLOAD выполнен';" +
        "} catch {" +
        "  if ($_.Exception.Response) { try { $code=[int]$_.Exception.Response.StatusCode.value__ } catch { $code=-1 } } else { $code=-1 };" +
        "  $msg=$_.Exception.Message;" +
        "}" +
        "$obj=@{ step='UPLOAD'; code=$code; message=$msg };" +
        "$obj | ConvertTo-Json -Compress";

      return runPsAndCapture(ps);
    }

    function startUpload() {
      var repoUrl = $("repoUrl").value.replace(/^\s+|\s+$/g, "");
      var repoPath = $("repoPath").value.replace(/^\s+|\s+$/g, "");
      var filePath = $("filePath").value.replace(/^\s+|\s+$/g, "");
      var user = $("user").value;
      var pass = $("pass").value;

      if (!repoUrl) { logLine("ОШИБКА: заполните URL репозитория."); return; }
      if (!filePath) { logLine("ОШИБКА: выберите файл."); return; }
      if (!user) { logLine("ОШИБКА: заполните логин."); return; }
      if (!pass) { logLine("ОШИБКА: заполните пароль."); return; }

      var fileName = getFileName(filePath);
      if (!fileName) {
        logLine("ОШИБКА: не удалось определить имя файла.");
        return;
      }

      var artifactUrl = joinUrl(repoUrl, repoPath, fileName);
      logLine("Старт операции.");
      logLine("Целевой URL: " + artifactUrl);
      logLine("Этап 1/2: DELETE предыдущего файла (если существует)...");

      var delResRaw = doDelete(artifactUrl, user, pass);
      if (delResRaw.exitCode !== 0 && !delResRaw.stdout) {
        logLine("ОШИБКА выполнения DELETE: " + (delResRaw.stderr || "код " + delResRaw.exitCode));
        return;
      }

      var delInfo = parseJsonSafe(delResRaw.stdout);
      if (!delInfo) {
        logLine("ОШИБКА: не удалось разобрать ответ DELETE: " + delResRaw.stdout);
        return;
      }

      var delCode = Number(delInfo.code);
      if (delCode >= 200 && delCode < 300) {
        logLine("DELETE успешно, HTTP " + delCode + ".");
      } else if (delCode === 403 || delCode === 404 || delCode === 405) {
        logLine("DELETE вернул HTTP " + delCode + ", продолжаем загрузку по правилу.");
      } else {
        logLine("ОШИБКА DELETE, HTTP " + delCode + ". Операция остановлена. Сообщение: " + delInfo.message);
        return;
      }

      logLine("Этап 2/2: UPLOAD нового файла...");
      var upResRaw = doUpload(artifactUrl, user, pass, filePath);
      if (upResRaw.exitCode !== 0 && !upResRaw.stdout) {
        logLine("ОШИБКА выполнения UPLOAD: " + (upResRaw.stderr || "код " + upResRaw.exitCode));
        return;
      }

      var upInfo = parseJsonSafe(upResRaw.stdout);
      if (!upInfo) {
        logLine("ОШИБКА: не удалось разобрать ответ UPLOAD: " + upResRaw.stdout);
        return;
      }

      var upCode = Number(upInfo.code);
      if (upCode >= 200 && upCode < 300) {
        logLine("UPLOAD успешно завершен, HTTP " + upCode + ".");
        logLine("Готово.");
      } else {
        logLine("ОШИБКА UPLOAD, HTTP " + upCode + ". Сообщение: " + upInfo.message);
      }
    }
  </script>
</head>
<body>
  <h2>Загрузка файла в Nexus Raw Hosted</h2>

  <div class="row">
    <span class="lbl">URL репозитория:</span>
    <input id="repoUrl" class="ctrl" type="text" value="http://localhost:8081/repository/my-raw" />
  </div>

  <div class="row">
    <span class="lbl">Подпуть в репозитории:</span>
    <input id="repoPath" class="ctrl" type="text" placeholder="например: releases/app" />
  </div>

  <div class="row">
    <span class="lbl">Локальный файл:</span>
    <input id="filePath" type="text" class="ctrl" />
    <button onclick="pickFile();">Выбрать...</button>
  </div>

  <div class="row">
    <span class="lbl">Пользователь Nexus:</span>
    <input id="user" class="ctrl" type="text" />
  </div>

  <div class="row">
    <span class="lbl">Пароль Nexus:</span>
    <input id="pass" class="ctrl" type="password" />
  </div>

  <div class="row" style="margin-left: 184px;">
    <button onclick="startUpload();">Удалить и загрузить</button>
    <button onclick="clearLog();">Очистить лог</button>
  </div>

  <div class="row">
    <span class="lbl">Лог (memo):</span><br />
    <textarea id="memo" readonly="readonly"></textarea>
  </div>
</body>
</html>
